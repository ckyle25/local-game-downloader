<UserControl x:Class="LocalGameDownloader.LocalGameDownloaderSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Foreground="{DynamicResource TextBrush}"
             TextElement.Foreground="{DynamicResource TextBrush}"
             d:DesignHeight="420"
             d:DesignWidth="720">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Margin="0,0,12,12"
                       VerticalAlignment="Center"
                       Text="Manifest Source" />
            <TextBox Grid.Row="0"
                     Grid.Column="1"
                     Margin="0,0,8,12"
                     Text="{Binding Settings.ManifestLocation, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Row="0"
                    Grid.Column="2"
                    Width="90"
                    Margin="0,0,8,12"
                    Click="BrowseManifestButton_Click"
                    Content="Browse..." />
            <Button Grid.Row="0"
                    Grid.Column="3"
                    Width="70"
                    Margin="0,0,0,12"
                    Click="ClearManifestButton_Click"
                    Content="Clear" />

            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Grid.ColumnSpan="3"
                       Margin="0,0,0,12"
                       Foreground="{DynamicResource TextBrushDarker}"
                       TextWrapping="Wrap"
                       Text="Use either an https:// manifest URL or a local .json file path. If left blank, the plugin will prompt the next time you open it." />

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Margin="0,0,12,12"
                       VerticalAlignment="Center"
                       Text="Default Install Root" />
            <TextBox Grid.Row="2"
                     Grid.Column="1"
                     Margin="0,0,8,12"
                     IsReadOnly="True"
                     Text="{Binding Settings.DefaultInstallRoot}" />
            <Button Grid.Row="2"
                    Grid.Column="2"
                    Width="90"
                    Margin="0,0,8,12"
                    Click="BrowseInstallRootButton_Click"
                    Content="Browse..." />
            <Button Grid.Row="2"
                    Grid.Column="3"
                    Width="70"
                    Margin="0,0,0,12"
                    Click="ClearInstallRootButton_Click"
                    Content="Clear" />

            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Margin="0,0,12,12"
                       VerticalAlignment="Center"
                       Text="7-Zip Path" />
            <TextBox Grid.Row="3"
                     Grid.Column="1"
                     Margin="0,0,8,12"
                     IsReadOnly="True"
                     Text="{Binding Settings.SevenZipPath}" />
            <Button Grid.Row="3"
                    Grid.Column="2"
                    Width="90"
                    Margin="0,0,8,12"
                    Click="AutoDetectSevenZipButton_Click"
                    Content="Detect" />
            <Button Grid.Row="3"
                    Grid.Column="3"
                    Width="70"
                    Margin="0,0,0,12"
                    Click="BrowseSevenZipButton_Click"
                    Content="Browse" />

            <CheckBox Grid.Row="4"
                      Grid.Column="1"
                      Grid.ColumnSpan="3"
                      Margin="0,4,0,12"
                      IsChecked="{Binding Settings.DeleteArchiveOnSuccess}"
                      Content="Delete archive file after successful extraction" />

            <TextBlock Grid.Row="5"
                       Grid.Column="0"
                       Grid.ColumnSpan="4"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextBrushDarker}"
                       Text="The plugin will try PATH, the default Program Files 7-Zip folders, and common registry locations before it asks the user to browse manually." />
        </Grid>
    </ScrollViewer>
</UserControl>
